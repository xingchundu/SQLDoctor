# 复制为 .env 后按需修改（.env 已被 git 忽略）

# —— Ollama 对话模型（RAG 诊断 /api/rag/diagnose 等会用到）——
# 名称须与 `ollama list` 中一致，例如 deepseek-r1:1.5b
LLM_MODEL=deepseek-r1:1.5b

# Ollama 本机地址（默认即可；若改端口再改这里）
OLLAMA_BASE_URL=http://127.0.0.1:11434

# 一般留空即可；程序会拼成 {OLLAMA_BASE_URL}/v1 访问 OpenAI 兼容 Chat API
# LLM_OPENAI_BASE_URL=http://127.0.0.1:11434/v1

# Ollama 不需要真实 Key，可不写；写了也会被接受
# LLM_API_KEY=ollama

# —— 知识库 / RAG 向量（默认启用）——
# 需已安装：langchain-huggingface、sentence-transformers、faiss-cpu（见 requirements.txt）
# HF：未设置时程序默认 https://hf-mirror.com；必须官方站时取消下行注释：
# SQLDOCTOR_HF_OFFICIAL=1
# 或指定其它端点：
# HF_ENDPOINT=https://hf-mirror.com
# KB_ENABLED=true
# 不需要 RAG、想加快启动时：
# KB_ENABLED=false
